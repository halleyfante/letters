---
import BaseLayout from "./BaseLayout.astro";
import { translate, translateCapitalized, defaultLanguage } from "../configuration/internationalization/translate";
import { formatDate } from "../configuration/date";

const author = "Halleyfante";

interface Props {
  title: string;
  description: string;
  topic: string;
  language: string;
  publishedDate: Date;
  updatedDate?: Date;
}

const { title, description, topic, language = defaultLanguage, publishedDate, updatedDate } = Astro.props;

const greeting = `${translateCapitalized("dear", language)} ${translate("human", language)},`;
const closing = `${translateCapitalized("sincerely", language)},`;
const topicLabel = translateCapitalized(topic, language);

const formattedPublishedDate = formatDate(publishedDate);
const formattedUpdatedDate = updatedDate ? formatDate(updatedDate) : undefined;
---

<BaseLayout
  title={title}
  description={description}
  breadcrumb={[
    { label: "home", href: import.meta.env.BASE_URL },
    { label: topicLabel, href: `${import.meta.env.BASE_URL}${topic}` },
    { label: title }
  ]}
>
  <article class="post-article">
    <header class="post-header">
      <h1 class="post-title">{title}</h1>
      <div class="post-metadata">
        <time datetime={publishedDate.toISOString()}>
          {formattedPublishedDate}
        </time>
        {formattedUpdatedDate && (
          <span class="post-updated">
            · atualizado em {formattedUpdatedDate}
          </span>
        )}
      </div>
    </header>
    <div class="post-content">
      <p class="letter-greeting">{greeting}</p>
      <slot />
      <footer class="letter-signature">
        <p>{closing} {author}.</p>
      </footer>
    </div>
  </article>
</BaseLayout>

<style>
  .post-article {
    max-width: 100%;
  }

  .post-header {
    margin-bottom: var(--amber-spacing-extra-large);
  }

  .post-topic-link {
    font-size: var(--amber-font-size-small);
    text-transform: lowercase;
    letter-spacing: 0.05em;
    color: var(--amber-color-accent);
  }

  .post-title {
    font-size: var(--amber-font-size-huge);
    margin: var(--amber-spacing-small) 0 var(--amber-spacing-medium);
  }

  .post-metadata {
    font-size: var(--amber-font-size-small);
    color: var(--amber-color-text-muted);
  }

  .post-updated {
    color: var(--amber-color-text-muted);
  }

  .post-content {
    font-size: var(--amber-font-size-medium);
    line-height: var(--amber-line-height-relaxed);
    text-align: justify;
  }

  .post-content :global(h2) {
    font-size: var(--amber-font-size-extra-large);
    margin-top: var(--amber-spacing-huge);
    margin-bottom: var(--amber-spacing-medium);
  }

  .post-content :global(h3) {
    font-size: var(--amber-font-size-large);
    margin-top: var(--amber-spacing-extra-large);
    margin-bottom: var(--amber-spacing-medium);
  }

  .post-content :global(p) {
    margin-bottom: var(--amber-spacing-medium);
  }

  .post-content :global(pre) {
    margin-bottom: var(--amber-spacing-large);
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin-bottom: var(--amber-spacing-medium);
    padding-left: var(--amber-spacing-large);
  }

  .post-content :global(li) {
    margin-bottom: var(--amber-spacing-small);
  }

  .post-content :global(blockquote) {
    border-left: 3px solid var(--amber-color-accent);
    padding-left: var(--amber-spacing-large);
    margin: var(--amber-spacing-large) 0;
    color: var(--amber-color-text-secondary);
    font-style: italic;
  }

  .post-content :global(sup) {
    font-size: inherit;
    vertical-align: baseline;
    line-height: inherit;
  }

  @media (max-width: 640px) {
    .post-title {
      font-size: var(--amber-font-size-extra-large);
      word-wrap: break-word;
      overflow-wrap: break-word;
    }

    .post-content {
      font-size: var(--amber-font-size-base);
      text-align: left;
    }

    .post-content :global(h2) {
      font-size: var(--amber-font-size-large);
    }

    .post-content :global(h3) {
      font-size: var(--amber-font-size-medium);
    }

    .post-content :global(blockquote) {
      padding-left: var(--amber-spacing-medium);
    }

    .post-content :global(ul),
    .post-content :global(ol) {
      padding-left: var(--amber-spacing-medium);
    }
  }
</style>
