---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import { THEME_KEY } from "../constants";

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  title: string;
  description: string;
  breadcrumb?: BreadcrumbItem[];
}

const { title, description, breadcrumb } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <script is:inline define:vars={{ themeKey: THEME_KEY }}>
      (function () {
        const stored = localStorage.getItem(themeKey);
        if (stored) {
          document.documentElement.setAttribute("data-theme", stored);
        } else if (window.matchMedia("(prefers-color-scheme: light)").matches) {
          document.documentElement.setAttribute("data-theme", "honey");
        } else {
          document.documentElement.setAttribute("data-theme", "darling");
        }
      })();
    </script>
    <Header breadcrumb={breadcrumb} />
    <main class="site-main">
      <slot />
    </main>
  </body>
</html>

<style>
  .site-main {
    max-width: 48rem;
    margin: 0 auto;
    padding: var(--amber-spacing-extra-large) var(--amber-spacing-large);
  }

  @media (max-width: 640px) {
    .site-main {
      padding: var(--amber-spacing-large) var(--amber-spacing-medium);
    }
  }
</style>
