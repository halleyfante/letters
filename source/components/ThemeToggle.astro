<button
  id="theme-toggle-button"
  type="button"
  aria-label="Alternar tema"
  class="theme-toggle"
>
  <svg class="theme-icon theme-icon-sun" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="5"></circle>
    <line x1="12" y1="1" x2="12" y2="3"></line>
    <line x1="12" y1="21" x2="12" y2="23"></line>
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
    <line x1="1" y1="12" x2="3" y2="12"></line>
    <line x1="21" y1="12" x2="23" y2="12"></line>
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
  </svg>
  <svg class="theme-icon theme-icon-moon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
</button>

<style>
  .theme-toggle {
    background: none;
    border: none;
    padding: var(--spacing-extra-small);
    cursor: pointer;
    color: var(--color-text-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--border-radius-small);
    transition: color 150ms;
  }

  .theme-toggle:hover {
    color: var(--color-accent);
  }

  .theme-icon-sun {
    display: none;
  }

  :global([data-theme="light"]) .theme-icon-sun {
    display: block;
  }

  :global([data-theme="light"]) .theme-icon-moon {
    display: none;
  }
</style>

<script>
  import { Theme, configure, get, set, ThemeLocalStorage } from "@halleyfante/amber/theme";

  configure({ storage: new ThemeLocalStorage("theme-preference") });

  const themeToggleButton = document.getElementById("theme-toggle-button");

  themeToggleButton?.addEventListener("click", () => {
    const { theme } = get();
    set(theme === Theme.Light ? Theme.Dark : Theme.Light);
  });
</script>
