---
import ThemeToggle from "./ThemeToggle.astro";
import Breadcrumb from "./Breadcrumb.astro";

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  breadcrumb?: BreadcrumbItem[];
}

const { breadcrumb = [{ label: "home" }] } = Astro.props;
---

<header class="site-header">
  <div class="header-content">
    <Breadcrumb items={breadcrumb} />
    <ThemeToggle />
    <div></div>
  </div>
</header>

<style>
  .site-header {
    border-bottom: var(--amber-border-width-thin) solid var(--amber-color-border);
    padding: var(--amber-spacing-medium) var(--amber-spacing-large);
  }

  .header-content {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
  }
</style>
