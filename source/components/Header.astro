---
import ThemeToggle from "./ThemeToggle.astro";
import Breadcrumb from "./Breadcrumb.astro";

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  breadcrumb?: BreadcrumbItem[];
}

const { breadcrumb = [{ label: "home" }] } = Astro.props;
---

<header class="site-header">
  <div class="header-content">
    <Breadcrumb items={breadcrumb} />
    <ThemeToggle />
  </div>
</header>

<style>
  .site-header {
    border-bottom: var(--amber-border-width-thin) solid var(--amber-color-border);
    padding: var(--amber-spacing-medium) var(--amber-spacing-large);
  }

  .header-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--amber-spacing-medium);
  }

  .header-content > :global(.breadcrumb) {
    flex: 1;
    min-width: 0;
  }

  @media (max-width: 640px) {
    .site-header {
      padding: var(--amber-spacing-small) var(--amber-spacing-medium);
    }
  }
</style>
