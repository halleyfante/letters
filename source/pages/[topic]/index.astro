---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { translateCapitalized } from "../../configuration/internationalization/translate";
import { formatDate } from "../../configuration/date";
import { byDateDescending, getSlug } from "../../configuration/posts";


export async function getStaticPaths() {
  const allPosts = await getCollection("posts", ({ data }) => !data.draft);
  const topics = [...new Set(allPosts.map((post) => post.data.topic))];

  return topics.map((topic) => ({
    params: { topic },
    props: {
      posts: allPosts
        .filter((post) => post.data.topic === topic)
        .sort(byDateDescending),
    },
  }));
}

const { topic } = Astro.params;
const { posts } = Astro.props;
const topicLabel = translateCapitalized(topic!);
---

<BaseLayout
  title={topicLabel}
  description={`Todos os posts sobre ${topicLabel}`}
  breadcrumb={[
    { label: "home", href: import.meta.env.BASE_URL },
    { label: topicLabel }
  ]}
>
  <section class="topic-page">
    <h1 class="topic-heading">{topicLabel}</h1>
    <ul class="post-list">
      {posts.map((post) => {
        const slug = getSlug(post);
        const formattedDate = formatDate(post.data.publishedDate);

        return (
          <li class="post-list-item">
            <a
              href={`${import.meta.env.BASE_URL}${post.data.topic}/${slug}`}
              class="post-link"
            >
              <span class="post-link-title">{post.data.title}</span>
              <span class="post-link-description">{post.data.description}</span>
            </a>
            <time
              class="post-link-date"
              datetime={post.data.publishedDate.toISOString()}
            >
              {formattedDate}
            </time>
          </li>
        );
      })}
    </ul>
  </section>
</BaseLayout>

<style>
  .topic-page {
    max-width: 100%;
  }

  .topic-heading {
    font-size: var(--amber-font-size-huge);
    margin-bottom: var(--amber-spacing-extra-large);
  }

  .post-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--amber-spacing-large);
  }

  .post-list-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--amber-spacing-medium);
    padding-bottom: var(--amber-spacing-large);
    border-bottom: var(--amber-border-width-thin) solid var(--amber-color-border);
  }

  .post-link {
    display: flex;
    flex-direction: column;
    gap: var(--amber-spacing-extra-small);
  }

  .post-link-title {
    font-size: var(--amber-font-size-medium);
    font-weight: var(--amber-font-weight-medium);
    color: var(--amber-color-text-primary);
    transition: color 150ms;
  }

  .post-link:hover .post-link-title {
    color: var(--amber-color-accent);
  }

  .post-link-description {
    font-size: var(--amber-font-size-small);
    color: var(--amber-color-text-secondary);
  }

  .post-link-date {
    font-size: var(--amber-font-size-small);
    color: var(--amber-color-text-muted);
    white-space: nowrap;
  }
</style>
