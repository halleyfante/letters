---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PostList from "../components/PostList.astro";
import { formatDate } from "../configuration/date";
import { byDateDescending, getSlug } from "../configuration/posts";

const allPosts = await getCollection("posts", ({ data }) => !data.draft);

const sortedPosts = allPosts.sort(byDateDescending);

const topics = [...new Set(allPosts.map((post) => post.data.topic))].sort();

const postListItems = sortedPosts.map((post) => ({
  title: post.data.title,
  topic: post.data.topic,
  url: `${import.meta.env.BASE_URL}${post.data.topic}/${getSlug(post)}`,
  publishedDate: formatDate(post.data.publishedDate),
}));
---

<BaseLayout title="Letters" description="Letters from HalleyFante">
  <div class="presentation">
    <div class="author-portrait">
      <amber-self-portrait variant="pix" caption="@halleyfante" badge></amber-self-portrait>
    </div>
    <p class="description">
      Em tempo em que qualquer fala pode dar lugar à problematização, ainda que nada de grave nela se diga, expressar uma ideia não deveria ser problema, quando o que se busca por seu meio é a reflexão.
    </p>
  </div>

  <PostList posts={postListItems} topics={topics} />
</BaseLayout>

<script>
  import { defineCustomElement } from "@halleyfante/amber/sdk/amber-self-portrait";
  defineCustomElement();
</script>

<style>
  .presentation {
    display: flex;
    align-items: stretch;
    gap: var(--amber-spacing-large);
    margin-bottom: var(--amber-spacing-extra-large);
  }

  .author-portrait amber-self-portrait {
    --amber-self-portrait-size: 14rem;
  }

  .description {
    flex: 1;
    margin: 0;
    padding: var(--amber-spacing-large);
    background-color: var(--amber-color-background-secondary);
    border: var(--amber-border-width-thin) solid var(--amber-color-border);
    border-radius: var(--amber-border-radius-medium);
    display: flex;
    align-items: center;
    font-size: var(--amber-font-size-medium);
    line-height: var(--amber-line-height-relaxed);
    text-align: justify;
    hyphens: auto;
  }
</style>
